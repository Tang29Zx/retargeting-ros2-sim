# Keep source files LF across Windows/Linux.
* text=auto eol=lf

*.py text eol=lf
*.sh text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.msg text eol=lf
*.cfg text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Windows-only command files may stay CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
